{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "asp_classic",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "asp_directive"
          },
          {
            "type": "SYMBOL",
            "name": "asp_expression"
          },
          {
            "type": "SYMBOL",
            "name": "asp_block"
          },
          {
            "type": "SYMBOL",
            "name": "server_script_block"
          },
          {
            "type": "SYMBOL",
            "name": "include_directive"
          },
          {
            "type": "SYMBOL",
            "name": "html_content"
          },
          {
            "type": "SYMBOL",
            "name": "html_lt"
          }
        ]
      }
    },
    "asp_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%@"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "string"
              },
              {
                "type": "SYMBOL",
                "name": "identifier"
              },
              {
                "type": "STRING",
                "value": "="
              },
              {
                "type": "PATTERN",
                "value": "[^%]"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "asp_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%="
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_code_token"
          }
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "asp_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_code_token"
          }
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "server_script_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "<script[^>]*runat\\s*=\\s*[\"']?server[\"']?[^>]*>",
          "flags": "i"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_code_token"
          }
        },
        {
          "type": "PATTERN",
          "value": "<\\/script>",
          "flags": "i"
        }
      ]
    },
    "include_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<!--"
        },
        {
          "type": "STRING",
          "value": "#include"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "file",
              "flags": "i"
            },
            {
              "type": "PATTERN",
              "value": "virtual",
              "flags": "i"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "STRING",
          "value": "-->"
        }
      ]
    },
    "_code_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "'"
              },
              {
                "type": "PATTERN",
                "value": "[^\\r\\n]*"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "rem[ \\t]",
                "flags": "i"
              },
              {
                "type": "PATTERN",
                "value": "[^\\r\\n]*"
              }
            ]
          }
        ]
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"]*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\d+(\\.\\d+)?"
          },
          {
            "type": "PATTERN",
            "value": "&H[0-9A-Fa-f]+"
          },
          {
            "type": "PATTERN",
            "value": "&O[0-7]+"
          }
        ]
      }
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-zA-Z_][a-zA-Z0-9_]*"
      }
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "STRING",
            "value": "<>"
          },
          {
            "type": "STRING",
            "value": "<="
          },
          {
            "type": "STRING",
            "value": ">="
          },
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "STRING",
            "value": ">"
          },
          {
            "type": "STRING",
            "value": "+"
          },
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "STRING",
            "value": "^"
          },
          {
            "type": "STRING",
            "value": "&"
          }
        ]
      }
    },
    "punctuation": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "("
          },
          {
            "type": "STRING",
            "value": ")"
          },
          {
            "type": "STRING",
            "value": ","
          },
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "STRING",
            "value": ":"
          }
        ]
      }
    },
    "html_content": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "REPEAT1",
          "content": {
            "type": "PATTERN",
            "value": "[^<]"
          }
        }
      }
    },
    "html_lt": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -2,
        "content": {
          "type": "STRING",
          "value": "<"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}